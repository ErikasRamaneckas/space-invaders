{
  "compilerOptions": {
    "outDir": "./dist", // Specify the output directory for compiled files
    "rootDir": "./src", // Specify the root directory of your TypeScript files
    "strict": true, // Enable all strict type-checking options (optional)
    "module": "esnext", // Specify the module system
    "target": "esnext", // Specify the target ECMAScript version
    "esModuleInterop": true // Allow default imports from CommonJS modules
  },
  "include": ["src"], // Include files to compile
  "exclude": ["node_modules"] // Exclude certain files and directories
}
